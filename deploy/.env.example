# Image to deploy. CI overwrites this with :sha tag for pinned rollouts.
JOB_HUNT_IMAGE=docker.toastedbytes.com/job-hunt-app:latest

# Postgres
POSTGRES_DB=job_hunt
POSTGRES_USER=job_hunt
# openssl rand -base64 36
POSTGRES_PASSWORD=

# API auth — OPTIONAL. Leave blank for single-user local mode (no auth).
# Set this before sharing the API with anyone else, then send as
# `Authorization: Bearer <token>` on every /api/v1 request.
# openssl rand -base64 32
JOB_HUNT_API_TOKEN=

# Optional
LOG_LEVEL=info
