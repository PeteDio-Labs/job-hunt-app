# Image to deploy. CI overwrites this with :sha tag for pinned rollouts.
JOB_HUNT_IMAGE=docker.toastedbytes.com/job-hunt-app:latest

# Postgres
POSTGRES_DB=job_hunt
POSTGRES_USER=job_hunt
# openssl rand -base64 36
POSTGRES_PASSWORD=

# REST /api/v1 bearer token. Used by CI/cron/shell. MCP uses Authentik OAuth (below).
# openssl rand -base64 32
JOB_HUNT_API_TOKEN=

# --- MCP OAuth via Authentik ---
# Required for the /mcp endpoint to work. Mirrors the OIDC provider configured in
# Authentik (see infrastructure/ansible/playbooks/authentik-oauth-providers.yml).
AUTHENTIK_BASE_URL=https://auth.toastedbytes.com
AUTHENTIK_APP_SLUG=job-hunt
AUTHENTIK_CLIENT_ID=job-hunt-mcp
# From the vault: vault_job_hunt_oauth_secret. Required.
AUTHENTIK_CLIENT_SECRET=

# Public URL clients use to reach this service (used in OAuth metadata).
PUBLIC_BASE_URL=https://job-hunt.toastedbytes.com

# Optional
LOG_LEVEL=info
